{
  "name": "markflow",
  "version": "0.4.0",
  "description": "A minimalist Chrome sidepanel extension for capturing web content as Markdown",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "wxt",
    "dev:firefox": "wxt --browser firefox",
    "build": "wxt build",
    "build:firefox": "wxt build --browser firefox",
    "zip": "wxt zip",
    "zip:firefox": "wxt zip --browser firefox",
    "typecheck": "tsc --noEmit",
    "test:e2e": "wxt build && playwright test",
    "test:e2e:ui": "wxt build && playwright test --ui",
    "test:e2e:debug": "wxt build && playwright test --debug"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  },
  "packageManager": "pnpm@10.10.0",
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@tailwindcss/vite": "^4.2.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@wxt-dev/module-react": "^1.2.2",
    "tailwindcss": "^4.2.2",
    "typescript": "^6.0.2",
    "wxt": "^0.20.21"
  },
  "dependencies": {
    "@milkdown/kit": "^7.20.0",
    "@milkdown/theme-nord": "^7.20.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5"
  }
}
